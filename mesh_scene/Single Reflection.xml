<scene version="2.1.0">

	<!-- Defaults, these can be set via the command line: -Darg=value -->


	<!-- Camera and Rendering Parameters -->

	<integrator type="path" id="elm__0" name="elm__0">
		<integer name="max_depth" value="12" />
	</integrator>

	<!-- Materials -->

	<bsdf type="diffuse" id="mat-itu_concrete" name="mat-itu_concrete">
		<rgb value="1.000000 0.000000 0.300000" name="reflectance" />
	</bsdf>
	<bsdf type="diffuse" id="mat-itu_marble" name="mat-itu_marble">
		<rgb value="0.284233 0.146437 0.061892" name="reflectance" />
	</bsdf>
	<bsdf type="diffuse" id="mat-itu_metal" name="mat-itu_metal">
		<rgb value="0.290000 0.250000 0.210000" name="reflectance" />
	</bsdf>

	<!-- Emitters -->

	<emitter type="constant" id="World" name="World">
		<rgb value="1.000000 1.000000 1.000000" name="radiance" />
	</emitter>

	<!-- Shapes -->

	<!-- Floor: 20x20 meters -->
	<shape type="ply" id="mesh-Piano" name="mesh-Piano">
		<string name="filename" value="meshes/Piano.ply" />
		<boolean name="face_normals" value="true" />
		<ref id="mat-itu_concrete" name="bsdf" />
		<transform name="to_world">
			<!-- <scale x="10" y="10" z="1" /> -->
			<scale x="1" y="1" z="1" />
		</transform>
	</shape>

	<!-- Building 1: Target dimensions 7m (width) × 10m (length) × 3m (height) at position (0, 10, 0)
	     Blender default cube is 2×2×2 units, so we scale by (3.5, 5, 1.5)
	     - Width: 2 × 3.5 = 7m
	     - Length: 2 × 5 = 10m
	     - Height: 2 × 1.5 = 3m
	     Transform order: scale first, then translate
	     Z-translation = 1.5m to place bottom on floor (half of 3m height) -->
	<shape type="ply" id="mesh-building1" name="mesh-building1">
		<string name="filename" value="custom/meshes/Cube.ply" />
		<boolean name="face_normals" value="true" />
		<ref id="mat-itu_marble" name="bsdf" />
		<transform name="to_world">
			<scale x="3.5" y="5" z="1.5" />
			<translate x="0" y="10" z="1.5" />
		</transform>
	</shape>

	<!-- Building 2: Target dimensions 12m (width) × 8m (length) × 3m (height) at position (8, 0, 0)
	     Blender default cube is 2×2×2 units, so we scale by (6, 4, 1.5)
	     - Width: 2 × 6 = 12m
	     - Length: 2 × 4 = 8m
	     - Height: 2 × 1.5 = 3m
	     Transform order: scale first, then translate
	     Z-translation = 1.5m to place bottom on floor (half of 3m height) -->
	<shape type="ply" id="mesh-building2" name="mesh-building2">
		<string name="filename" value="custom/meshes/Cube.ply" />
		<boolean name="face_normals" value="true" />
		<ref id="mat-itu_marble" name="bsdf" />
		<transform name="to_world">
			<scale x="6" y="4" z="1.5" />
			<translate x="8" y="0" z="1.5" />
		</transform>
	</shape>

	<!-- Volumes -->

</scene>